{% extends 'base.html.twig' %}

{% block title %}Edit Article{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8">
                <h1>Edit Article</h1>

                {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <button type="submit" class="btn btn-primary">Update</button>
                    <a href="{{ path('app_article_show', {id: article.id}) }}" class="btn btn-secondary">Back to article</a>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %} 