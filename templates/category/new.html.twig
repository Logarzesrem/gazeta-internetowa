{% extends 'base.html.twig' %}

{% block title %}{{ 'category.new'|trans({}, 'admin') }}{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="row">
            <div class="col-md-8">
                <h1>{{ 'category.create_new'|trans({}, 'admin') }}</h1>

                {{ form_start(form) }}
                    {{ form_widget(form) }}
                    <button type="submit" class="btn btn-primary">{{ 'category.create'|trans({}, 'admin') }}</button>
                    <a href="{{ path('app_category_index') }}" class="btn btn-secondary">{{ 'category.back_to_list'|trans({}, 'admin') }}</a>
                {{ form_end(form) }}
            </div>
        </div>
    </div>
{% endblock %} 