{% extends 'base.html.twig' %}

{% block title %}Manage Users - Admin Panel{% endblock %}

{% block body %}
<div class="container mt-4">
    <div class="row">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h1>Manage Users</h1>
                <a href="{{ path('admin_dashboard') }}" class="btn btn-secondary">Back to Dashboard</a>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <h5 class="mb-0">Registered Users ({{ total }})</h5>
                        </div>
                        <div class="col-md-6 text-md-end">
                            <small class="text-muted">
                                Sort by: 
                                <a href="{{ path('admin_users_list', {sort: 'createdAt', direction: sortField == 'createdAt' and sortDirection == 'DESC' ? 'ASC' : 'DESC', page: page}) }}" class="text-decoration-none {{ sortField == 'createdAt' ? 'fw-bold' : '' }}">
                                    Date
                                </a> |
                                <a href="{{ path('admin_users_list', {sort: 'username', direction: sortField == 'username' and sortDirection == 'ASC' ? 'DESC' : 'ASC', page: page}) }}" class="text-decoration-none {{ sortField == 'username' ? 'fw-bold' : '' }}">
                                    Username
                                </a> |
                                <a href="{{ path('admin_users_list', {sort: 'email', direction: sortField == 'email' and sortDirection == 'ASC' ? 'DESC' : 'ASC', page: page}) }}" class="text-decoration-none {{ sortField == 'email' ? 'fw-bold' : '' }}">
                                    Email
                                </a>
                            </small>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    {% if users|length > 0 %}
                        <div class="table-responsive">
                            <table class="table table-striped">
                                <thead>
                                    <tr>
                                        <th>ID</th>
                                        <th>Username</th>
                                        <th>Email</th>
                                        <th>Name</th>
                                        <th>Status</th>
                                        <th>Created</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for user in users %}
                                        <tr>
                                            <td>{{ user.id }}</td>
                                            <td>
                                                <strong>{{ user.username }}</strong>
                                                {% if user.bio %}
                                                    <br><small class="text-muted">{{ user.bio|slice(0, 50) }}{% if user.bio|length > 50 %}...{% endif %}</small>
                                                {% endif %}
                                            </td>
                                            <td>{{ user.email }}</td>
                                            <td>{{ user.name }}</td>
                                            <td>
                                                {% if user.isActive %}
                                                    <span class="badge bg-success">Active</span>
                                                {% else %}
                                                    <span class="badge bg-danger">Inactive</span>
                                                {% endif %}
                                            </td>
                                            <td>
                                                <small>{{ user.createdAt|date('M j, Y') }}</small><br>
                                                <small class="text-muted">{{ user.createdAt|date('H:i') }}</small>
                                            </td>
                                            <td>
                                                <div class="btn-group btn-group-sm" role="group">
                                                    <a href="{{ path('admin_user_view', {id: user.id}) }}" class="btn btn-outline-primary" title="View Profile">
                                                        <i class="bi bi-eye"></i>
                                                    </a>
                                                    <a href="{{ path('admin_regular_user_edit', {id: user.id}) }}" class="btn btn-outline-warning" title="Edit User">
                                                        <i class="bi bi-pencil"></i>
                                                    </a>
                                                    {% if user.isActive %}
                                                        <a href="{{ path('admin_user_deactivate', {id: user.id}) }}" class="btn btn-outline-danger" title="Deactivate User">
                                                            <i class="bi bi-person-x"></i>
                                                        </a>
                                                    {% else %}
                                                        <a href="{{ path('admin_user_activate', {id: user.id}) }}" class="btn btn-outline-success" title="Activate User">
                                                            <i class="bi bi-person-check"></i>
                                                        </a>
                                                    {% endif %}
                                                    <form method="POST" action="{{ path('admin_regular_user_delete', {id: user.id}) }}" style="display: inline;" onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.')">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}" />
                                                        <button type="submit" class="btn btn-outline-danger" title="Delete User">
                                                            <i class="bi bi-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>

                        {% if total > 10 %}
                            <nav aria-label="User pagination">
                                <ul class="pagination justify-content-center">
                                    {% set pages = (total / 10)|round(0, 'ceil') %}
                                    {% for i in 1..pages %}
                                        <li class="page-item {{ page == i ? 'active' : '' }}">
                                            <a class="page-link" href="{{ path('admin_users_list', {page: i, sort: sortField, direction: sortDirection}) }}">{{ i }}</a>
                                        </li>
                                    {% endfor %}
                                </ul>
                            </nav>
                        {% endif %}
                    {% else %}
                        <div class="text-center py-4">
                            <i class="bi bi-people fs-1 text-muted"></i>
                            <h5 class="mt-3">No Users Found</h5>
                            <p class="text-muted">No users have registered yet.</p>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %} 